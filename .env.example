# ── Database (REQUIRED) ───────────────────────────────────────────────
# Format: mysql+pymysql://USER:URL_ENCODED_PASSWORD@HOST:3306/DBNAME
# Note: special characters in password must be URL-encoded (; = %3B, @ = %40, etc.)
DATABASE_URL=mysql+pymysql://USER:URL_ENCODED_PASSWORD@HOST:3306/DBNAME

# ── SambaNova (REQUIRED — primary NL2SQL provider) ────────────────────
# Comma-separated list of API keys; rotated automatically on 429
SAMBANOVA_API_KEYS=key1,key2,key3

# ── Gemini (recommended — fallback after SambaNova) ───────────────────
GEMINI_API_KEYS=key1,key2

# ── Groq (optional — last-resort fallback) ────────────────────────────
GROQ_API_KEY_1=
GROQ_API_KEY_2=

# ── CORS ──────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000

# ── App ───────────────────────────────────────────────────────────────
ENVIRONMENT=development
