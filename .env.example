# ── Database (optional) ───────────────────────────────────────────────
# If unset, app/db/database.py uses its hardcoded fallback.
DATABASE_URL=mysql+pymysql://USER:PASSWORD@HOST:3306/DBNAME

# ── CORS ──────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000

# ── LLM API Keys (optional — code has hardcoded fallbacks) ────────────
# SambaNova is primary, Gemini and Groq are fallbacks.
SAMBANOVA_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY_1=
GROQ_API_KEY_2=

# ── App environment ───────────────────────────────────────────────────
ENVIRONMENT=development
