# Database - Main ERP database
DATABASE_URL=mysql+pymysql://USER:PASSWORD@HOST:3306/DBNAME

# Database - Local chatbot operations (entity_aliases, feedback, etc.)
LOCAL_DATABASE_URL=mysql+pymysql://root:@127.0.0.1:3306/chatbot

# CORS Origins (comma-separated, no spaces)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000

# LLM API Keys (optional - fallback to Ollama if not provided)
SAMBANOVA_API_KEY=your_sambanova_key_here
GEMINI_API_KEY=your_gemini_key_here
GROQ_API_KEY_1=your_groq_key_here
GROQ_API_KEY_2=your_second_groq_key_here

# Ollama (local LLM fallback)
OLLAMA_BASE_URL=http://localhost:11434

# Application
ENVIRONMENT=development
